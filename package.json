{
  "name": "pi-resume",
  "version": "1.0.2",
  "description": "Fast session resume for pi coding agent — /r1../r5 ranked instant resume, /rs paginated picker, /rds subagent session cleanup",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "session",
    "resume"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/spex66/pi-fast-resume.git"
  },
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules --test tests/*.test.ts",
    "check": "npm run typecheck && npm pack --dry-run",
    "prepublishOnly": "npm run check"
  }
}
